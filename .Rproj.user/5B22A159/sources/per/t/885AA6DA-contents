Rcpp::List de_rcpp(int n, int m, int s, int NP, int itermax,
                   double pMut, double pCR, double pGBest,
                  int replicates){
  double time_taken;
  IntegerMatrix X(n, m);
  NumericVector opt_val(replicates);
  DE_C(&n, &m, &s, &NP, &itermax,  &pMut, &pCR, &pGBest, X.begin(),
        opt_val.begin(), &time_taken, &replicates);
  List results;
  results["opt_val"] = opt_val;
  results["time_taken"] = time_taken;
  if(replicates == 1) results["X"] = X;
  return results;

}

